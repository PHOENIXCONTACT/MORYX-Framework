<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <OutputType>Library</OutputType>
    <IsPackable>true</IsPackable>
    <GenerateSBOM>true</GenerateSBOM>
    <SbomGenerationFetchLicenseInformation>true</SbomGenerationFetchLicenseInformation>
    <SbomGenerationManifestInfo>SPDX:3.0</SbomGenerationManifestInfo>
    <Description>MQTT for ASP.NET Core</Description>
    <PackageReadmeFile>asp-net-core-mqtt.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Sbom.Targets" PrivateAssets="All" />
    <PackageReference Include="MQTTnet" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Moryx\Moryx.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\docs\articles\mqtt\asp-net-core-mqtt.md" Pack="true" PackagePath="" />
  </ItemGroup>
</Project>
