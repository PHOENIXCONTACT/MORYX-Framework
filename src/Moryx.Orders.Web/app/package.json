{
  "name": "moryx.orders.web",
  "version": "10.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development",
    "build": "ng build",
    "build:prod": "ng build --delete-output-path --configuration production --progress false",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate-api": "NODE_TLS_REJECT_UNAUTHORIZED=0 ng-openapi-gen -c openapi-gen.json && node ../../fix-openapi-gen.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.0",
    "@angular/cdk": "^21.1.0",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-browser-dynamic": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@fontsource/roboto": "^5.2.9",
    "@moryx/ngx-web-framework": "^21.1.0",
    "material-icons": "^1.13.14",
    "material-symbols": "^0.40.2",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "ngx-doc-viewer": "^21.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.0",
    "@angular/cli": "^21.1.0",
    "@angular/compiler-cli": "^21.1.0",
    "jsdom": "^29.0.1",
    "ng-openapi-gen": "^1.0.5",
    "typescript": "~5.9.3",
    "vitest": "^4.0.8"
  }
}
