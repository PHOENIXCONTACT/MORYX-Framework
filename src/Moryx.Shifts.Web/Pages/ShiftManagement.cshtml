@page "{*_}"
@using Microsoft.AspNetCore.Authorization;
@using System.ComponentModel.DataAnnotations
@using Moryx.Modules
@using Moryx.Shifts.Web.Properties

@{
    ViewData["Title"] = "Shifts Management";
    ViewData["BaseRef"] = "ShiftManagement/";

    Layout = "_Layout";
}
@attribute [WebModule("ShiftManagement", "calendar_month"),
  Display(ResourceType = typeof(Strings), Name = nameof(Strings.Module_Title), Description = nameof(Strings.Module_Description)),
    AllowAnonymous]

<!DOCTYPE html>

@section Styles {
    <link rel="stylesheet" href="/_content/Moryx.Shifts.Web/styles.css">
}
@section Scripts
{
  <script src="/_content/Moryx.Shifts.Web/main.js" type="module"></script>
}

<app-root></app-root>
